{
  "app_name": "Job Credits Tracker",
  "version": "1.0",
  "description": "Mobile-first PWA for tracking weekly job credits against an adjustable target. Engineers log jobs throughout the day, add deductions, and track whether they've hit their weekly bonus target.",

  "conversion": {
    "formula": "credits = minutes / 83.58",
    "basis": "56 minutes = 0.67 job credits"
  },

  "weekly_target": {
    "default_base_hours": 40,
    "adjustable": true,
    "notes": "Base hours adjustable per user. Deductions (travel, absences, waiting etc.) are subtracted from base hours to get adjusted target. Total earned credits (converted to hours) must exceed adjusted target for bonus. Travel data arrives ~10 days after the week, so previous weeks must be editable."
  },

