  "deductions": {
    "description": "Single bucket for all non-productive time. Entered in hours/minutes. Subtracted from base weekly hours to calculate adjusted target.",
    "categories": "None - all deductions are entered as a single total",
    "entry_format": "hours and minutes",
    "editable_retroactively": true,
    "notes": "Travel data arrives ~10 days after the week. Users need to go back and update previous weeks with travel deductions when this data becomes available."
  },

  "app_requirements": {
    "platform": "Mobile-first PWA (installable on phone), also accessible via browser for others to download/use",
    "storage": "Local storage on device with ability to view and edit previous weeks",
    "features": [
      "Set adjustable base weekly hours (default 40)",
      "Log jobs by tapping job type - instant credit calculation",
      "Trace & Repair and INSHV-TRV prompt for minutes input",
      "Upgrade Work prompts for hours quoted input",
      "Log boiler lead sales credits",
      "Log deductions in hours/minutes",
      "Daily breakdown view within the week",
      "Weekly dashboard: total earned credits (hours) vs adjusted target",
      "Clear indicator of whether bonus target is met",
      "Edit previous weeks (especially for adding travel deductions ~10 days later)",
      "Week history - view past weeks and their results"
    ]
  }
